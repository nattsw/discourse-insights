function projectX(lng) {
  return lng + 180;
}

function projectY(lat) {
  return 90 - lat;
}

export default class InsightsGeoMap extends Component {
  @tracked hoveredCountry = null;
  @tracked tooltipStyle = "";

  get maxCount() {
    return Math.max(...this.args.data.map((d) => d.count), 1);
  }

  get bubbles() {
    return this.args.data
      .filter((d) => d.latitude != null && d.longitude != null)
      .map((d) => {
        const r = 2.5 + Math.sqrt(d.count / this.maxCount) * 10;
        const opacity = 0.35 + (d.count / this.maxCount) * 0.5;
        return {
          cx: projectX(d.longitude),
          cy: projectY(d.latitude),
          r,
          style: htmlSafe(`opacity:${opacity}`),
          ...d,
        };
      });
  }

  @action
  onBubbleEnter(bubble, event) {
    this.hoveredCountry = bubble;
    const svg = event.currentTarget.closest("svg");
    const rect = svg.getBoundingClientRect();
    const x = event.clientX - rect.left;
    const y = event.clientY - rect.top;
    this.tooltipStyle = htmlSafe(`left:${x}px;top:${y - 8}px`);
  }

  @action
  onBubbleLeave() {
    this.hoveredCountry = null;
  }

  <template>
    <div class="insights-geo-map">
      <svg viewBox="0 0 360 180" preserveAspectRatio="xMidYMid meet">
        <path d={{LAND_PATH}} class="insights-geo-map__land" />

        {{#each this.bubbles as |b|}}
          <circle
            cx={{b.cx}}
            cy={{b.cy}}
            r={{b.r}}
            class="insights-geo-map__bubble"
            style={{b.style}}
            {{on "mouseenter" (fn this.onBubbleEnter b)}}
            {{on "mouseleave" this.onBubbleLeave}}
          />
        {{/each}}
      </svg>

      {{#if this.hoveredCountry}}
        <div class="insights-geo-map__tooltip" style={{this.tooltipStyle}}>
          <strong>{{this.hoveredCountry.country}}</strong>
          <span>{{this.hoveredCountry.count}}
            ({{this.hoveredCountry.pct}}%)</span>
        </div>
      {{/if}}
    </div>
  </template>
}
